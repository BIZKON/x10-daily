# === БД ===
DATABASE_URL=postgresql://USER:PASS@HOST/x10?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASS@HOST/x10?sslmode=require

# === Timeweb AI Gateway (OpenAI-совместимый proxy для Claude / GPT / Gemini) ===
# Подтверждено: base URL = https://api.timeweb.ai/v1, SDK = openai (НЕ anthropic).
# Модели именуются с префиксом `anthropic/...` для Claude (см. ЛК Timeweb).
# 152-ФЗ покрывается DPA с Timeweb — Masker / ZDR не нужны.
AI_GATEWAY_URL=https://api.timeweb.ai/v1
AI_GATEWAY_API_KEY=
# Model IDs (выбираются через `model` параметр в OpenAI Chat Completions request).
ANTHROPIC_MODEL_OPUS=anthropic/claude-opus-4-7
ANTHROPIC_MODEL_SONNET=anthropic/claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=anthropic/claude-haiku-4-5

# === Legacy: direct Anthropic API (без proxy) — для emergency fallback ===
# Не используется в prod. Если когда-нибудь захотим обойти Timeweb — задать
# ANTHROPIC_API_KEY + ANTHROPIC_ZDR_CONFIRMED=true (после подписания ZDR).
ANTHROPIC_API_KEY=
ANTHROPIC_ZDR_CONFIRMED=false

# === ElevenLabs (через свой WS-proxy на Render для РФ) ===
ELEVENLABS_API_KEY=
ELEVENLABS_PROXY_URL=

# === KikuAI Masker (PII redaction, 152-ФЗ) ===
MASKER_BASE_URL=
MASKER_API_KEY=

# === Telegram session auth (HIGH-2) ===
# BOT_TOKEN — корень доверия для initData / Login Widget verification.
# Required в production (без него Telegram-сессии не выпускаются).
# Формат: <bot_id>:<secret>, получить у @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=
# JWT secret для подписи сессий (HS256, минимум 32 байта). Required в production.
# Generate: openssl rand -base64 48
X10_JWT_SECRET=
# TTL сессии в секундах. Default 86400 (24h). Перелогин дешёвый.
X10_JWT_TTL_SECONDS=86400
# Bot username (без @) для admin Telegram Login Widget на /login странице.
# Должен совпадать с зарегистрированным в @BotFather login_domain.
# Public env — попадает в браузер (нужен для рендера виджета).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# === MAX (VK Platform Bridge) ===
MAX_BOT_TOKEN=
MAX_WEBAPP_URL=

# === Timeweb S3 хранилище (S3-compatible) ===
# Прод-хранилище для аватаров / обложек. До session 15 был Cloudflare R2.
# Endpoint берётся из ЛК Timeweb при создании бакета (например https://s3.twcstorage.ru).
# X10_IMAGES_PUBLIC_BASE = публичный URL bucket (для генерации ссылок в article.coverImageUrl).
S3_ENDPOINT=
S3_REGION=ru-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=x10-images
X10_IMAGES_PUBLIC_BASE=

# === Redis (Timeweb DBaaS Managed) ===
# Используется для rate limit (engagement 30/мин, pipeline 10/мин) и Inngest queue.
# Формат: redis://default:PASSWORD@HOST:PORT/0
REDIS_URL=

# === Legacy: Cloudflare (был CF Workers до session 15) ===
# Не используется в prod после переезда на Timeweb. Сохранено для возможного
# emergency fallback (например preview deploys через CF Pages).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# === Resend (email — newsletter) ===
RESEND_API_KEY=

# === PostHog ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# === Sentry ===
SENTRY_DSN=

# === Inngest (workflow engine для AI-пайплайна) ===
# EVENT_KEY — для отправки событий из apps/api в Inngest cloud
# SIGNING_KEY — для верификации webhooks в apps/workers/pipeline
# Локальная разработка: `npx inngest-cli@latest dev` — ключи не нужны
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
