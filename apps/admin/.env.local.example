# X10 Admin — local env
#
# Скопируй в .env.local. Серверные переменные (без NEXT_PUBLIC_) в браузер не уходят.

# URL apps/api worker'а (Hono на Cloudflare Workers).
# Локально (см. docs/handoffs/handoff-session-8.md):
#   cd apps/api && pnpm wrangler dev --port 8788
X10_API_BASE_URL=http://localhost:8788

# UUID admin-пользователя (X-User-Id header в server actions).
# MVP-stub до Telegram session auth. Должен совпадать с записью в users где role IN ('editor','admin').
# Сгенерируй UUID: uuidgen или https://www.uuidgenerator.net/
X10_ADMIN_USER_ID=

# Image upload (Этап 3g) использует apps/api → R2.
# Конфиг bucket'a живёт в apps/api/.dev.vars (X10_IMAGES_PUBLIC_BASE) + wrangler.toml r2_buckets.
# Здесь, в admin, ничего дополнительно настраивать не нужно — upload идёт через server action.
