# X10 Daily — miniapp local env
#
# Скопируй в `.env.local` и подставь значения.

# URL apps/api worker'а (Hono на Cloudflare Workers).
# Локально (см. docs/handoffs/handoff-session-8.md, Terminal 3):
#   cd apps/api && pnpm wrangler dev --port 8788
# Без этой переменной miniapp работает на моках из src/lib/feed.ts —
# для разработки UI без полного стека это нормально.
X10_API_BASE_URL=http://localhost:8788
