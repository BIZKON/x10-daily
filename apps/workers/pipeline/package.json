{
  "name": "@x10/worker-pipeline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "inngest:dev": "npx inngest-cli@latest dev --no-discovery -u http://127.0.0.1:8787/inngest"
  },
  "dependencies": {
    "@x10/agents": "workspace:*",
    "@x10/config": "workspace:*",
    "@x10/db": "workspace:*",
    "hono": "^4.12.23",
    "inngest": "^4.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20260526.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
