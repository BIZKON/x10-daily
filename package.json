{
  "name": "x10-daily",
  "private": true,
  "version": "0.1.0",
  "description": "X10 Daily — ежедневное мини-апп-медиа на стеке 2026 (Next.js 16 + Hono + Cloudflare Workers + Neon + AI-пайплайн на Claude)",
  "packageManager": "pnpm@10.33.4",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck && tsc --noEmit -p scripts/tsconfig.json",
    "test": "turbo run test",
    "format": "biome format --write .",
    "check": "biome check --apply .",
    "db:seed": "pnpm --filter @x10/db db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "overrides": {
      "valibot@<1.2.0": ">=1.2.0"
    }
  }
}
